{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Bash-Debug Launch Current File",
            "type": "bashdb",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${file}",
            "terminalKind": "integrated"
        },
        {
            "type": "bashdb",
            "request": "launch",
            "name": "Bash-Debug (yana-tests)",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/yana_tests.sh",
            "args": [
                "-testfile",
                "${relativeFile}"
            ],
            "terminalKind": "integrated"
        },
        {
            "name": "PowerShell Launch Current File",
            "type": "PowerShell",
            "request": "launch",
            "script": "${file}",
            "cwd": "${cwd}",
            "createTemporaryIntegratedConsole": true
        },
        {
            "name": "PowerShell (yana-tests)",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/yana_tests.ps1",
            "cwd": "${workspaceFolder}",
            "args": [
                "-testfile",
                "${relativeFile}"
            ],
            "createTemporaryIntegratedConsole": true
        }
    ]
}
