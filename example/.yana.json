{
  "requires": [
    "bash",
    "apt-get"
  ],
  "params": {
    "app_dir": "/tmp/yana_demo",
    "config_file": "${param:app_dir}/config.env",
    "status_file": "${param:app_dir}/status.txt",
    "service_port": "8080"
  },
  "steps": [
    {
      "name": "Ensure application configuration exists",
      "action": "file.write",
      "args": {
        "path": "${param:config_file}",
        "content": "PORT=${param:service_port}\nDEPLOYED_AT=${var:iso_time}\nUSER=${env:USER}",
        "owner": "${var:user}"
      }
    },
    {
      "name": "Write marker file",
      "action": "file.write",
      "args": {
        "path": "${param:status_file}",
        "content": "STATUS=ACTIVE",
        "owner": "${var:user}"
      }
    }
  ]
}
